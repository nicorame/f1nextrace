---
import Layout from '../layouts/Layout.astro';
import RemotionTest from '../components/RemotionTest';
---

<Layout title="Remotion Test" description="Prueba de Remotion Player">
  <main style="min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2rem; gap: 1.5rem;">
    <h1 style="color: white; font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 0.15em;">
      Remotion Player — Prueba
    </h1>
    <div style="width: 100%; max-width: 860px;">
      <RemotionTest client:only="react" />
    </div>
  </main>
</Layout>
